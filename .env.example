# Single source of truth for environment configuration.
# Copy to .env and fill in the values for your project.

# --- Python config ---------------------------------------------------------

# Required: the GCP project ID that hosts Vertex AI, GCS, BigQuery, etc.
GCP_PROJECT_ID=your-gcp-project-id

# Optional: region for Vertex AI / GCS / Cloud Run.
GCP_REGION=us-central1

# Optional: Gemini model identifier (default gemini-2.5-flash).
# GEMINI_MODEL=gemini-2.5-flash

# Optional: process-wide cap on generate() calls (default 50).
# MAX_CALLS_PER_RUN=50

# --- Terraform variables ---------------------------------------------------
# The TF_VAR_ prefix tells Terraform to bind these as input variables, so
# we don't need a separate terraform.tfvars file. The Makefile loads .env
# into the shell before running terraform commands.

TF_VAR_project_id=your-gcp-project-id
TF_VAR_region=us-central1
TF_VAR_env=dev
TF_VAR_name_prefix=sqc
